# 環境變數範本檔案
# 請將此檔案複製為 .env 並填入您的實際金鑰
# .env 檔案已被 .gitignore 忽略，不會被上傳到版本庫

# --- 資料庫設定 ---
# 本機開發 (Local Development): 使用安裝在您自己電腦上的 MongoDB
MONGODB_URI="mongodb://localhost:27017/yuanyu"

# VPS 上的 Docker 資料庫 (Docker DB on VPS): 連接到在同一台主機上運行的 Docker 容器
# MONGODB_URI="mongodb://<user>:<password>@localhost:27017/yuanyu?authSource=admin"

# 自架遠端資料庫 (Self-Hosted Remote DB): 將 "localhost" 替換為您資料庫主機的 IP 位址，並填入使用者帳號與密碼
# MONGODB_URI="mongodb://<username>:<password>@your_database_host_ip:27017/yuanyu"

# 雲端資料庫 (Cloud Database - 例如 MongoDB Atlas): 將 "localhost" 替換為您的雲端連線字串
# MONGODB_URI="mongodb+srv://<username>:<password>@your-cluster.mongodb.net/yuanyu?retryWrites=true&w=majority"

# 您的主要管理員密碼 (ROOT權限)，可以設定多個，用逗號分隔
ADMIN_CODES="your_super_secret_code,another_one"

# 您的 Google GenAI API 金鑰
GENAI_API_KEY="your-google-genai-api-key-here"

# Crisp 客服網站 ID (若不需要此功能可留空)
CRISP_WEBSITE_ID=""